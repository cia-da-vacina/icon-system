{
  "name": "@cia-da-vacina/icon-system",
  "version": "0.1.0",
  "description": "Icon system for Cia da Vacina CRM",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react --external styled-components --external @cia-da-vacina/styled-system",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@cia-da-vacina/styled-system": ">=0.1.0",
    "react": ">=18",
    "styled-components": ">=6"
  },
  "devDependencies": {
    "@cia-da-vacina/styled-system": "file:../CiaVacinaStyledSystem",
    "@types/react": "^19.1.8",
    "react": "^19.1.0",
    "styled-components": "^6.4.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cia-da-vacina/icon-system.git"
  }
}
